; Engine configuration file.
; Sugar Street Tycoon: Match & Build — Match-3 Prototype

config_version=5

[application]

config/name="Sugar Street Tycoon: Match & Build"
config/description="Match-3 and dessert shop management prototype."
config/version="0.2.0"
run/main_scene="res://scenes/main/title_screen.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon/icon.png"

[autoload]

GameState="*res://scripts/shop/game_state.gd"
AudioManager="*res://scripts/audio/audio_manager.gd"
SceneRouter="*res://scripts/navigation/scene_router.gd"

[display]

window/size/viewport_width=405
window/size/viewport_height=720
window/size/window_width_override=405
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[input]

debug_print_board={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":49,"key_label":0,"unicode":49,"location":0,"echo":false,"script":null)
]
}
